# polybot — environment variables (single Rust binary)

DATABASE_URL= # replace with your own Postgres URL

COINALYZE_API_KEY=YOUR_COINALYZE_API_KEY

# OKX public v5 WebSocket — mark-price feed source for live inference
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public

# Which cryptos this bot trades (comma-separated, case-insensitive)
CRYPTOS=btc,eth,xrp,sol

# FRED API key (get Macro index such as DXY, SPX, VIX, yields):
FRED_API_KEY=YOUR_FRED_API_KEY_HERE

# Polymarket CLOB API
POLYMARKET_API_URL=https://clob.polymarket.com

# Polymarket Gamma API (market discovery, no auth)
GAMMA_API_URL=https://gamma-api.polymarket.com

# Polymarket WSS market channel (order-book subscriptions)
WSS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# EOA wallet private key (0x-prefixed) — signs orders
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket proxy wallet address (holds USDC.e, 0x-prefixed checksum)
# Required because this account is proxy-funded; orders sign with SignatureType::Proxy
POLYMARKET_FUNDER=0xYOUR_PROXY_WALLET_ADDRESS_HERE

# Max USDC per order
ORDER_MAX_NOTIONAL_USD=25

# Minimum model confidence to act on (0.0–1.0). With the 2-class UP/DOWN
# model this is the sole filter on low-conviction predictions — there is
# no HOLD class. 0.62 keeps a small margin above the 0.50 coin-flip line.
MIN_CONFIDENCE=0.62

# Seconds before window boundary to suppress orders
ENTRY_OFFSET_SECS=10

# ── EV gate + spread filter (trading-layer profit gates) ─────────────────────
# These sit downstream of MIN_CONFIDENCE (the cheap upstream pre-gate). Instead
# of gating on probability alone, the trader gates on expected value per share:
#     EV = p_calibrated - best_ask - fee_frac      (Polymarket binary: $1/$0)
# and skips wide books that would eat the edge on fills.

# Minimum EV per share (USD, net of fee) to admit a trade. 0.02 = 2¢/share.
EV_MIN_EDGE=0.02

# Max top-of-book spread in basis points of mid before skipping. 300 = 3%.
MAX_SPREAD_BPS=300

# Kill switch for the EV gate. false → bypass EV gate (spread filter still
# fires), falling back to the MIN_CONFIDENCE gate without a redeploy.
EV_GATE_ENABLED=true

# Staleness threshold for book cache entries (ms)
BOOK_STALENESS_MS=2000

# How far ahead of a window rollover to pre-subscribe to next token_ids (sec)
PREWARM_LEAD_SECS=30

# Startup wallet pre-flight check. When true (default), `polybot run` queries
# the CLOB /balance-allowance endpoint and bails if the funder can't cover at
# least one ORDER_MAX_NOTIONAL_USD order. Set to false for dry-run / offline
# development where no live order placement is expected.
PREFLIGHT_ENABLED=true

# Paper-trading mode. When true, `polybot run` executes the full prediction
# pipeline (features → inference → gating → market resolution) but skips
# OrderManager + BookStream + preflight — no live orders are placed. A
# background task compares each predicted action against the resolved
# Polymarket outcome and records hit/miss rows in `dry_run_results`.
DRY_RUN=true

# First-deploy self-bootstrap. When true (default), if one or more configured
# symbols have no current model row in the DB at startup, `polybot run`
# automatically fetches 60 days of candles and trains the missing models
# in-process before entering the live loop. Set to false to skip bootstrap
# entirely — missing models are logged and those symbols are just not traded.
BOOTSTRAP_ON_EMPTY=true

# Logging level
RUST_LOG=info
